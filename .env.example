# ── 사이트 로그인 정보 ──
YANGJU_ID=your_id
YANGJU_PW=your_password

# ── 카카오 API (알림용) ──
# https://developers.kakao.com 에서 앱 등록 후 발급
KAKAO_REST_API_KEY=your_kakao_rest_api_key
KAKAO_ACCESS_TOKEN=your_access_token
KAKAO_REFRESH_TOKEN=your_refresh_token
KAKAO_MYPAGE_URL=your_mypage_url

# ── AI API KEY (선택, CAPTCHA 폴백용) ──
OPENAI_API_KEY=

# ── Google Drive (스크린샷 업로드용, 선택) ──
# Google Cloud Console > API 및 서비스 > OAuth 2.0 클라이언트 ID
# Drive API 활성화 필요
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# 업로드할 폴더 ID (선택, 미지정 시 루트)
GOOGLE_DRIVE_FOLDER_ID=

# ── 기타 ──
LOG_LEVEL=info
