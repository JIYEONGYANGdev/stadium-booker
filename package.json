{
  "name": "stadium-booker",
  "version": "1.0.0",
  "description": "공공체육시설 구장 예약 자동화 CLI",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "stadium-booker": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "reserve": "tsx src/index.ts book --config config/config.yaml",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "cosmiconfig": "^9.0.0",
    "dotenv": "^16.4.7",
    "inquirer": "^12.3.2",
    "node-cron": "^3.0.3",
    "openai": "^6.27.0",
    "playwright": "^1.50.1",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "tesseract.js": "^5.1.1",
    "winston": "^3.17.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^22.13.4",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
